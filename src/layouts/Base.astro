---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Void 1680 AM — Broadcast Archive' } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title} — WBPR 1680 AM</title>
  <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
</head>
<body>
  <header class="site-header">
    <div class="container--wide">
      <div class="site-header__inner">
        <a href={base} class="site-header__brand">WBPR 1680 AM</a>
        <nav>
          <ul class="site-nav">
            <li><a href={`${base}archive`}>Archive</a></li>
            <li><a href={`${base}veil`}>Veil</a></li>
            <li><a href={`${base}phenomena`}>Phenomena</a></li>
            <li><a href={`${base}soundtrack`}>Soundtrack</a></li>
          </ul>
        </nav>
      </div>
    </div>
  </header>

  <main>
    <slot />
  </main>

  <footer class="site-footer">
    <div class="container--wide">
      <p class="site-footer__inner">WBPR 1680 AM &mdash; Broadcasting until the signal holds.</p>
    </div>
  </footer>
</body>
</html>
