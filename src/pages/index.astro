---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import SessionCard from '../components/SessionCard.astro';
import { buildPhenomenaIndex } from '../utils/phenomenaIndex';

const allSessions = await getCollection('sessions');
const sessions = allSessions.sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
const latest = sessions[0];

const phenomenaIndex = await buildPhenomenaIndex();
const activePhenomena = [...phenomenaIndex.values()].filter(
  p => ['Escalating', 'Active', 'New'].includes(p.latestStatus)
);

const base = import.meta.env.BASE_URL;

function statusClass(status: string) {
  return `badge badge--${status.toLowerCase()}`;
}
---

<Base title="WBPR 1680 AM" description="Void 1680 AM — Broadcast Archive">
  <div class="container">

    <section class="station-intro">
      <div class="station-intro__signal mono"><span class="signal-dot" aria-hidden="true"></span>SIGNAL ACQUIRED · WBPR 1680 AM</div>
      <h1 class="station-intro__name">Void 1680 AM</h1>
      <div class="station-intro__freq mono">1680 kHz · AM Broadcast · Supernatural Archive</div>
      <p class="station-intro__desc">
        A broadcast archive. Sessions logged from the edges of the dial.
        The Veil thins at certain hours. The signal finds those who need it.
      </p>
    </section>

    {latest && (
      <section class="latest-section">
        <h2 class="section-label mono"><span class="on-air-dot" aria-hidden="true"></span>Latest Broadcast</h2>
        <SessionCard
          session={latest.data.session}
          station={latest.data.station}
          call_sign={latest.data.call_sign}
          location={latest.data.location}
          date={latest.data.date}
          veil_status={latest.data.veil_status}
          veil_intensity={latest.data.veil_intensity}
          callers={latest.data.callers}
          tags={latest.data.tags}
          slug={latest.id.replace(/\.md$/, '')}
        />
      </section>
    )}

    {activePhenomena.length > 0 && (
      <section class="active-phenomena">
        <h2 class="section-label mono">Active Phenomena</h2>
        <div class="phenomena-grid">
          {activePhenomena.map(p => (
            <a href={`${base}phenomena/${p.key}`} class="phenom-mini">
              <div class="phenom-mini__header">
                <span class="phenom-mini__name">{p.name}</span>
                <span class={statusClass(p.latestStatus)}>{p.latestStatus}</span>
              </div>
              {p.allLocations.length > 0 && (
                <span class="phenom-mini__loc mono">{p.allLocations[0]}</span>
              )}
            </a>
          ))}
        </div>
      </section>
    )}

    <nav class="index-nav">
      <a href={`${base}archive`} class="index-nav__link">
        <span class="index-nav__title">Archive <span class="index-nav__arrow" aria-hidden="true">→</span></span>
        <span class="index-nav__sub mono">All sessions</span>
      </a>
      <a href={`${base}phenomena`} class="index-nav__link">
        <span class="index-nav__title">Phenomena <span class="index-nav__arrow" aria-hidden="true">→</span></span>
        <span class="index-nav__sub mono">Cross-session events</span>
      </a>
      <a href={`${base}soundtrack`} class="index-nav__link">
        <span class="index-nav__title">Soundtrack <span class="index-nav__arrow" aria-hidden="true">→</span></span>
        <span class="index-nav__sub mono">Music index</span>
      </a>
    </nav>

  </div>
</Base>

<style>
  /* ── Hero ─────────────────────────────────────────────── */

  .station-intro {
    padding: var(--space-2xl) 0;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: var(--space-2xl);
    position: relative;
  }

  .station-intro::after {
    content: '';
    position: absolute;
    bottom: -1px;
    left: 0;
    width: 80px;
    height: 1px;
    background: var(--color-accent-dim);
  }

  .station-intro__signal {
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-accent-dim);
    margin-bottom: var(--space-lg);
    display: flex;
    align-items: center;
    gap: var(--space-sm);
  }

  .signal-dot {
    display: inline-block;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--color-accent);
    flex-shrink: 0;
    animation: signal-pulse 2.5s ease-in-out infinite;
  }

  .station-intro__name {
    font-size: clamp(2.8rem, 7vw, 5.5rem);
    letter-spacing: -0.02em;
    line-height: 1.05;
    margin-bottom: var(--space-md);
    text-shadow: 0 0 80px rgba(212, 165, 116, 0.12);
  }

  .station-intro__freq {
    font-size: 0.62rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-text-dim);
    margin-bottom: var(--space-xl);
  }

  .station-intro__desc {
    font-size: 1.05rem;
    color: var(--color-text-muted);
    max-width: 500px;
    line-height: 1.8;
    margin: 0;
    border-left: 2px solid var(--color-border);
    padding-left: var(--space-md);
  }

  /* ── Section labels ────────────────────────────────────── */

  .section-label {
    font-size: 0.65rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-text-dim);
    margin-bottom: var(--space-lg);
    font-weight: 400;
    display: flex;
    align-items: center;
    gap: var(--space-md);
    white-space: nowrap;
  }

  .section-label::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--color-border);
  }

  .on-air-dot {
    display: inline-block;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--color-accent);
    flex-shrink: 0;
    animation: signal-pulse 2s ease-in-out infinite;
  }

  /* ── Sections ──────────────────────────────────────────── */

  .latest-section {
    margin-bottom: var(--space-2xl);
  }

  .active-phenomena {
    margin-bottom: var(--space-2xl);
  }

  /* ── Phenomena mini-cards ──────────────────────────────── */

  .phenomena-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: var(--space-sm);
  }

  .phenom-mini {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    padding: var(--space-md);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-surface);
    text-decoration: none;
    transition: border-color var(--transition), background var(--transition);
  }

  .phenom-mini:hover {
    border-color: var(--color-accent-dim);
    background: var(--color-surface-raised);
  }

  .phenom-mini__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-sm);
    flex-wrap: wrap;
  }

  .phenom-mini__name {
    font-size: 0.9rem;
    color: var(--color-text);
    font-family: var(--font-serif);
  }

  .phenom-mini__loc {
    font-size: 0.68rem;
    color: var(--color-text-dim);
    letter-spacing: 0.04em;
  }

  /* ── Navigation cards ──────────────────────────────────── */

  .index-nav {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-sm);
    margin-bottom: var(--space-2xl);
  }

  .index-nav__link {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    padding: var(--space-lg) var(--space-lg) var(--space-xl);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-surface);
    text-decoration: none;
    transition: border-color var(--transition), background var(--transition), border-left-color var(--transition);
  }

  .index-nav__link:hover {
    border-color: var(--color-accent-dim);
    border-left-color: var(--color-accent);
    background: var(--color-surface-raised);
  }

  .index-nav__title {
    font-family: var(--font-serif);
    font-size: 1.2rem;
    color: var(--color-text);
    display: flex;
    align-items: baseline;
    justify-content: space-between;
  }

  .index-nav__arrow {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--color-accent-dim);
    opacity: 0;
    transform: translateX(-6px);
    transition: opacity var(--transition), transform var(--transition), color var(--transition);
  }

  .index-nav__link:hover .index-nav__arrow {
    opacity: 1;
    transform: translateX(0);
    color: var(--color-accent);
  }

  .index-nav__sub {
    font-size: 0.7rem;
    letter-spacing: 0.06em;
    color: var(--color-text-dim);
  }

  /* ── Responsive ────────────────────────────────────────── */

  @media (max-width: 600px) {
    .station-intro__name { font-size: 2.4rem; }
    .index-nav { grid-template-columns: 1fr; }
  }
</style>
