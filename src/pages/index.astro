---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import SessionCard from '../components/SessionCard.astro';
import { buildPhenomenaIndex } from '../utils/phenomenaIndex';

const allSessions = await getCollection('sessions');
const sessions = allSessions.sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
const latest = sessions[0];

const phenomenaIndex = await buildPhenomenaIndex();
const activePhenomena = [...phenomenaIndex.values()].filter(
  p => ['Escalating', 'Active', 'New'].includes(p.latestStatus)
);

const base = import.meta.env.BASE_URL;

function statusClass(status: string) {
  return `badge badge--${status.toLowerCase()}`;
}
---

<Base title="WBPR 1680 AM" description="Void 1680 AM — Broadcast Archive">
  <div class="container">

    <section class="station-intro">
      <div class="station-intro__signal mono">SIGNAL ACQUIRED · WBPR 1680 AM</div>
      <h1 class="station-intro__name">Void 1680 AM</h1>
      <p class="station-intro__desc">
        A broadcast archive. Sessions logged from the edges of the dial.
        The Veil thins at certain hours. The signal finds those who need it.
      </p>
    </section>

    {latest && (
      <section class="latest-section">
        <h2 class="section-label mono">Latest Broadcast</h2>
        <SessionCard
          session={latest.data.session}
          station={latest.data.station}
          call_sign={latest.data.call_sign}
          location={latest.data.location}
          date={latest.data.date}
          veil_status={latest.data.veil_status}
          veil_intensity={latest.data.veil_intensity}
          callers={latest.data.callers}
          tags={latest.data.tags}
          slug={latest.id.replace(/\.md$/, '')}
        />
      </section>
    )}

    {activePhenomena.length > 0 && (
      <section class="active-phenomena">
        <h2 class="section-label mono">Active Phenomena</h2>
        <div class="phenomena-grid">
          {activePhenomena.map(p => (
            <a href={`${base}phenomena/${p.key}`} class="phenom-mini">
              <div class="phenom-mini__header">
                <span class="phenom-mini__name">{p.name}</span>
                <span class={statusClass(p.latestStatus)}>{p.latestStatus}</span>
              </div>
              {p.allLocations.length > 0 && (
                <span class="phenom-mini__loc mono">{p.allLocations[0]}</span>
              )}
            </a>
          ))}
        </div>
      </section>
    )}

    <nav class="index-nav">
      <a href={`${base}archive`} class="index-nav__link">
        <span class="index-nav__title">Archive</span>
        <span class="index-nav__sub mono">All sessions</span>
      </a>
      <a href={`${base}phenomena`} class="index-nav__link">
        <span class="index-nav__title">Phenomena</span>
        <span class="index-nav__sub mono">Cross-session events</span>
      </a>
      <a href={`${base}soundtrack`} class="index-nav__link">
        <span class="index-nav__title">Soundtrack</span>
        <span class="index-nav__sub mono">Music index</span>
      </a>
    </nav>

  </div>
</Base>

<style>
  .station-intro {
    padding: var(--space-2xl) 0;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: var(--space-2xl);
  }

  .station-intro__signal {
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-accent-dim);
    margin-bottom: var(--space-md);
  }

  .station-intro__name {
    font-size: 3rem;
    letter-spacing: -0.01em;
    margin-bottom: var(--space-md);
  }

  .station-intro__desc {
    font-size: 1rem;
    color: var(--color-text-muted);
    max-width: 520px;
    line-height: 1.75;
    margin: 0;
  }

  .section-label {
    font-size: 0.65rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-text-dim);
    margin-bottom: var(--space-lg);
    font-weight: 400;
  }

  .latest-section {
    margin-bottom: var(--space-2xl);
  }

  .active-phenomena {
    margin-bottom: var(--space-2xl);
  }

  .phenomena-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: var(--space-sm);
  }

  .phenom-mini {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    padding: var(--space-md);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-surface);
    text-decoration: none;
    transition: border-color var(--transition), background var(--transition);
  }

  .phenom-mini:hover {
    border-color: var(--color-accent-dim);
    background: var(--color-surface-raised);
  }

  .phenom-mini__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-sm);
    flex-wrap: wrap;
  }

  .phenom-mini__name {
    font-size: 0.9rem;
    color: var(--color-text);
    font-family: var(--font-serif);
  }

  .phenom-mini__loc {
    font-size: 0.68rem;
    color: var(--color-text-dim);
    letter-spacing: 0.04em;
  }

  .index-nav {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-sm);
    margin-bottom: var(--space-2xl);
  }

  .index-nav__link {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    padding: var(--space-lg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-surface);
    text-decoration: none;
    transition: border-color var(--transition), background var(--transition);
  }

  .index-nav__link:hover {
    border-color: var(--color-accent-dim);
    background: var(--color-surface-raised);
  }

  .index-nav__title {
    font-family: var(--font-serif);
    font-size: 1.1rem;
    color: var(--color-text);
  }

  .index-nav__sub {
    font-size: 0.7rem;
    letter-spacing: 0.06em;
    color: var(--color-text-dim);
  }

  @media (max-width: 600px) {
    .station-intro__name { font-size: 2rem; }
    .index-nav { grid-template-columns: 1fr; }
  }
</style>
