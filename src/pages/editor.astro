---
import Base from '../layouts/Base.astro';
---

<Base title="Session Log Editor" description="Full WYSIWYG editor for WBPR session logs — every block, every field, laid out on the page. Load an existing session to continue editing, or start fresh and export a finished .md file.">

  <div class="container--wide">
    <header class="page-header">
      <div class="eyebrow mono">WBPR 1680 AM &middot; Session Log Editor</div>
      <h1>Session Log Editor</h1>
      <p class="page-header__sub">
        Every block laid out on one page. Write the whole session here, load an
        existing <code>.md</code> file to keep editing it, and export a finished,
        schema-conformant file when you're done.
      </p>
    </header>

    <section class="toolbar">
      <label class="btn btn--primary file-btn">
        Load .md File
        <input id="f-upload" type="file" accept=".md,.markdown,text/markdown" hidden />
      </label>
      <button id="btn-new" class="btn">New Session</button>
      <button id="btn-recalc" class="btn">Recalculate Stats</button>
      <button id="btn-generate" class="btn btn--primary">Generate Output</button>
    </section>

    <div id="editor-root"></div>

    <section class="output-section" id="output-section" hidden>
      <h2 class="section-label mono">Generated .md</h2>
      <textarea id="output-text" class="output-text mono" readonly rows="24"></textarea>
      <div class="output-actions">
        <button id="btn-copy" class="btn">Copy</button>
        <button id="btn-download" class="btn">Download .md</button>
      </div>
    </section>
  </div>

</Base>

<style>
  .page-header {
    padding: var(--space-2xl) 0 var(--space-xl);
    border-bottom: 1px solid var(--color-border);
    margin-bottom: var(--space-xl);
  }
  .eyebrow {
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-accent-dim);
    margin-bottom: var(--space-md);
  }
  .page-header h1 { font-size: 2.2rem; margin-bottom: var(--space-md); }
  .page-header__sub {
    font-size: 1rem;
    color: var(--color-text-muted);
    max-width: 700px;
    line-height: 1.75;
    margin: 0;
  }

  .section-label {
    font-size: 0.65rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-text-dim);
    margin-bottom: var(--space-lg);
    font-weight: 400;
  }

  .toolbar {
    display: flex;
    gap: var(--space-sm);
    flex-wrap: wrap;
    margin-bottom: var(--space-xl);
  }

  .file-btn { position: relative; cursor: pointer; }

  .btn {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    background: var(--color-surface);
    color: var(--color-text-muted);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    padding: var(--space-sm) var(--space-lg);
    cursor: pointer;
    transition: border-color var(--transition), color var(--transition);
  }
  .btn:hover:not(:disabled) { border-color: var(--color-accent-dim); color: var(--color-accent); }
  .btn--primary { color: var(--color-accent); border-color: var(--color-accent-dim); }
  .btn--small { font-size: 0.65rem; padding: 2px 8px; }
  .btn--danger:hover { border-color: var(--color-caller-emergency); color: var(--color-caller-emergency); }

  .card {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-surface);
    padding: var(--space-lg);
    margin-bottom: var(--space-xl);
  }

  .card h2.section-label { margin-bottom: var(--space-lg); }

  .field-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: var(--space-md);
  }

  .field { display: flex; flex-direction: column; gap: var(--space-xs); margin-bottom: var(--space-md); }
  .field__label {
    font-size: 0.62rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-dim);
  }
  .field input, .field select, .field textarea {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    color: var(--color-text);
    font-family: var(--font-mono);
    font-size: 0.85rem;
    padding: var(--space-sm);
  }
  .field textarea { font-family: var(--font-serif); font-size: 0.95rem; resize: vertical; }
  .field input:focus, .field select:focus, .field textarea:focus { outline: 1px solid var(--color-accent-dim); }

  .block-card {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-surface-raised);
    padding: var(--space-lg);
    margin-bottom: var(--space-lg);
  }
  .block-card__head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-md);
    margin-bottom: var(--space-md);
  }
  .block-card__head h3 {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-accent);
  }
  .block-card__actions { display: flex; gap: var(--space-xs); }

  .sub-label {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-dim);
    margin: var(--space-md) 0 var(--space-xs);
  }

  .row {
    display: grid;
    grid-template-columns: 1fr 1fr auto;
    gap: var(--space-sm);
    margin-bottom: var(--space-xs);
    align-items: center;
  }
  .row--track { grid-template-columns: 2fr 1.5fr 2fr 1fr auto; }
  .row input {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    color: var(--color-text);
    font-family: var(--font-mono);
    font-size: 0.8rem;
    padding: var(--space-xs) var(--space-sm);
  }

  .phen-card {
    border: 1px solid var(--color-border-dim);
    border-radius: var(--radius-sm);
    padding: var(--space-md);
    margin-bottom: var(--space-md);
  }

  .output-section { margin-top: var(--space-xl); }
  .output-text {
    width: 100%;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    color: var(--color-text);
    font-size: 0.78rem;
    padding: var(--space-lg);
    margin-bottom: var(--space-md);
    resize: vertical;
  }
  .output-actions { display: flex; gap: var(--space-sm); }

  .add-row-btn { margin-top: var(--space-xs); }
</style>

<script>
  import {
    type SessionDoc,
    type BlockDoc,
    defaultSession,
    emptyBlock,
    emptyPrompt,
    emptyTrack,
    emptyPhenomenon,
    parseSessionMarkdown,
    buildSessionMarkdown,
    recalcStatsFromBlocks,
  } from '../utils/sessionDoc';
  import { initRun, rollBlockMechanics, veilStatusFor, type RunState } from '../utils/ruleset';

  let doc: SessionDoc = defaultSession();
  let rollState: RunState | null = null;

  const root = document.getElementById('editor-root') as HTMLElement;

  function esc(s: string): string {
    return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
  }

  function render() {
    root.innerHTML = `
      ${renderMeta()}
      ${renderBlocks()}
      ${renderPhenomena()}
      ${renderStats()}
      ${renderLists()}
    `;
  }

  function renderMeta(): string {
    const d = doc;
    return `
      <section class="card">
        <h2 class="section-label mono">Session Details</h2>
        <div class="field-grid">
          ${field('Session #', 'session', 'number', String(d.session))}
          ${field('Station', 'station', 'text', d.station)}
          ${field('Call Sign', 'call_sign', 'text', d.call_sign)}
          ${field('Location', 'location', 'text', d.location)}
          ${field('Coords Lat', 'coordinates.0', 'number', d.coordinates ? String(d.coordinates[0]) : '')}
          ${field('Coords Lon', 'coordinates.1', 'number', d.coordinates ? String(d.coordinates[1]) : '')}
          ${field('Date', 'date', 'date', d.date)}
          ${field('Start Time', 'start_time', 'time', d.start_time)}
          ${field('End Time', 'end_time', 'time', d.end_time)}
          ${field('Duration (minutes)', 'duration_minutes', 'number', String(d.duration_minutes))}
          ${field('Veil Status', 'veil_status', 'select', d.veil_status, ['Normal', 'Thin', 'Thick', 'Opaque'])}
          ${field('Veil Intensity', 'veil_intensity', 'number', String(d.veil_intensity))}
          ${field('Callers', 'callers', 'number', String(d.callers))}
        </div>
        <label class="field">
          <span class="field__label mono">Atmospheric Conditions</span>
          <textarea data-field="atmospheric_conditions" rows="2">${esc(d.atmospheric_conditions)}</textarea>
        </label>
      </section>
    `;
  }

  function field(label: string, name: string, type: string, value: string, options?: string[]): string {
    if (type === 'select' && options) {
      return `
        <label class="field">
          <span class="field__label mono">${label}</span>
          <select data-field="${name}">
            ${options.map(o => `<option value="${o}" ${o === value ? 'selected' : ''}>${o}</option>`).join('')}
          </select>
        </label>
      `;
    }
    return `
      <label class="field">
        <span class="field__label mono">${label}</span>
        <input data-field="${name}" type="${type}" value="${esc(value)}" />
      </label>
    `;
  }

  function renderBlocks(): string {
    return `
      <section class="card">
        <div class="block-card__head">
          <h2 class="section-label mono" style="margin-bottom:0;">Blocks</h2>
          <button class="btn btn--small" data-action="add-block">+ Add Block</button>
        </div>
        ${doc.blocks.map((b, i) => renderBlock(b, i)).join('')}
      </section>
    `;
  }

  function renderBlock(b: BlockDoc, i: number): string {
    return `
      <div class="block-card">
        <div class="block-card__head">
          <h3>Block ${i + 1}</h3>
          <div class="block-card__actions">
            <button class="btn btn--small" data-action="roll-block" data-block="${i}">Roll</button>
            <button class="btn btn--small btn--danger" data-action="remove-block" data-block="${i}">Remove</button>
          </div>
        </div>

        <label class="field">
          <span class="field__label mono">Time</span>
          <input data-block="${i}" data-field="time" type="time" value="${esc(b.time)}" />
        </label>

        <div class="sub-label">Prompts</div>
        ${b.prompts.map((p, pi) => `
          <div class="row">
            <input data-block="${i}" data-prompt="${pi}" data-field="card" placeholder="Card" value="${esc(p.card)}" />
            <input data-block="${i}" data-prompt="${pi}" data-field="tone" placeholder="Tone" value="${esc(p.tone)}" />
            <button class="btn btn--small btn--danger" data-action="remove-prompt" data-block="${i}" data-prompt="${pi}">&times;</button>
          </div>
        `).join('')}
        <button class="btn btn--small add-row-btn" data-action="add-prompt" data-block="${i}">+ Prompt</button>

        <div class="sub-label">Playlist</div>
        ${b.playlist.map((t, ti) => `
          <div class="row row--track">
            <input data-block="${i}" data-track="${ti}" data-field="title" placeholder="Title" value="${esc(t.title)}" />
            <input data-block="${i}" data-track="${ti}" data-field="artist" placeholder="Artist" value="${esc(t.artist)}" />
            <input data-block="${i}" data-track="${ti}" data-field="url" placeholder="URL" value="${esc(t.url)}" />
            <input data-block="${i}" data-track="${ti}" data-field="source" placeholder="Source" value="${esc(t.source)}" />
            <button class="btn btn--small btn--danger" data-action="remove-track" data-block="${i}" data-track="${ti}">&times;</button>
          </div>
        `).join('')}
        <button class="btn btn--small add-row-btn" data-action="add-track" data-block="${i}">+ Track</button>

        <div class="sub-label">Caller</div>
        <div class="field-grid">
          ${select(`caller_type`, i, b.caller_type, ['none', 'standard', 'phenomenon', 'emergency'], 'Type')}
          ${blockField('Caller Card', i, 'caller_card', b.caller_card)}
          ${blockField('Caller Card Meaning', i, 'caller_card_meaning', b.caller_card_meaning)}
          ${blockField('Phenomenon Ref', i, 'phenomenon_ref', b.phenomenon_ref)}
          ${blockField('Caller Location', i, 'caller_location', b.caller_location)}
          ${select(`caller_location_confidence`, i, b.caller_location_confidence, ['unknown', 'accent-only', 'approximate', 'precise'], 'Location Confidence')}
          ${blockField('Caller Coords Lat', i, 'caller_coords.0', b.caller_coords ? String(b.caller_coords[0]) : '', 'number')}
          ${blockField('Caller Coords Lon', i, 'caller_coords.1', b.caller_coords ? String(b.caller_coords[1]) : '', 'number')}
        </div>

        <div class="sub-label">Narrative</div>
        <label class="field">
          <textarea data-block="${i}" data-field="narrative" rows="5">${esc(b.narrative)}</textarea>
        </label>
      </div>
    `;
  }

  function blockField(label: string, blockIndex: number, name: string, value: string, type = 'text'): string {
    return `
      <label class="field">
        <span class="field__label mono">${label}</span>
        <input data-block="${blockIndex}" data-field="${name}" type="${type}" value="${esc(value)}" />
      </label>
    `;
  }

  function select(name: string, blockIndex: number, value: string, options: string[], label: string): string {
    return `
      <label class="field">
        <span class="field__label mono">${label}</span>
        <select data-block="${blockIndex}" data-field="${name}">
          ${options.map(o => `<option value="${o}" ${o === value ? 'selected' : ''}>${o}</option>`).join('')}
        </select>
      </label>
    `;
  }

  function renderPhenomena(): string {
    return `
      <section class="card">
        <div class="block-card__head">
          <h2 class="section-label mono" style="margin-bottom:0;">Phenomena Log</h2>
          <button class="btn btn--small" data-action="add-phen">+ Add Phenomenon</button>
        </div>
        ${doc.phenomena_log.map((p, i) => `
          <div class="phen-card">
            <div class="field-grid">
              ${phenField('Key', i, 'key', p.key)}
              ${phenField('Name', i, 'name', p.name)}
              ${phenSelect('status', i, p.status, ['New', 'Active', 'Stable', 'Escalating', 'Resolved', 'Dormant'], 'Status')}
              ${phenSelect('confidence', i, p.confidence, ['Unconfirmed', 'Likely', 'Confirmed'], 'Confidence')}
              ${phenField('Locations (comma-separated)', i, 'locations', p.locations.join(', '))}
              ${phenField('Tags (comma-separated)', i, 'tags', p.tags.join(', '))}
              ${phenField('Coords Lat', i, 'coords.0', p.coords ? String(p.coords[0]) : '', 'number')}
              ${phenField('Coords Lon', i, 'coords.1', p.coords ? String(p.coords[1]) : '', 'number')}
            </div>
            <label class="field">
              <span class="field__label mono">Notes</span>
              <textarea data-phen="${i}" data-field="notes" rows="3">${esc(p.notes)}</textarea>
            </label>
            <button class="btn btn--small btn--danger" data-action="remove-phen" data-phen="${i}">Remove</button>
          </div>
        `).join('')}
      </section>
    `;
  }

  function phenField(label: string, phenIndex: number, name: string, value: string, type = 'text'): string {
    return `
      <label class="field">
        <span class="field__label mono">${label}</span>
        <input data-phen="${phenIndex}" data-field="${name}" type="${type}" value="${esc(value)}" />
      </label>
    `;
  }

  function phenSelect(name: string, phenIndex: number, value: string, options: string[], label: string): string {
    return `
      <label class="field">
        <span class="field__label mono">${label}</span>
        <select data-phen="${phenIndex}" data-field="${name}">
          ${options.map(o => `<option value="${o}" ${o === value ? 'selected' : ''}>${o}</option>`).join('')}
        </select>
      </label>
    `;
  }

  function renderStats(): string {
    const s = doc.session_stats;
    return `
      <section class="card">
        <h2 class="section-label mono">Session Stats</h2>
        <div class="field-grid">
          ${statField('Blocks Completed', 'blocks_completed', String(s.blocks_completed))}
          ${statField('Total Callers', 'total_callers', String(s.total_callers))}
          ${statField('Phenomenon Callers', 'phenomenon_callers', String(s.phenomenon_callers))}
          ${statField('Standard Callers', 'standard_callers', String(s.standard_callers))}
          ${statField('Calls Resolved', 'calls_resolved', String(s.calls_resolved))}
          ${statField('Calls Unresolved', 'calls_unresolved', String(s.calls_unresolved))}
          ${statField('Dawn Colour', 'dawn_colour', s.dawn_colour, 'text')}
          ${statField('Veil at Close', 'veil_at_close', s.veil_at_close, 'text')}
        </div>
      </section>
    `;
  }

  function statField(label: string, name: string, value: string, type = 'number'): string {
    return `
      <label class="field">
        <span class="field__label mono">${label}</span>
        <input data-stat="${name}" type="${type}" value="${esc(value)}" />
      </label>
    `;
  }

  function renderLists(): string {
    return `
      <section class="card">
        <h2 class="section-label mono">Tags, Aliases &amp; Notes</h2>
        <div class="field-grid">
          <label class="field">
            <span class="field__label mono">Tags (comma-separated)</span>
            <input data-list="tags" type="text" value="${esc(doc.tags.join(', '))}" />
          </label>
          <label class="field">
            <span class="field__label mono">Aliases (comma-separated)</span>
            <input data-list="aliases" type="text" value="${esc(doc.aliases.join(', '))}" />
          </label>
          <label class="field">
            <span class="field__label mono">Related Sessions (comma-separated #s)</span>
            <input data-list="related_sessions" type="text" value="${esc(doc.related_sessions.join(', '))}" />
          </label>
          <label class="field">
            <span class="field__label mono">Notes Section Title</span>
            <input data-field="notesTitle" type="text" value="${esc(doc.notesTitle)}" />
          </label>
        </div>
        <label class="field">
          <span class="field__label mono">Personal Notes</span>
          <textarea data-field="notesBody" rows="6">${esc(doc.notesBody)}</textarea>
        </label>
      </section>
    `;
  }

  function setPath(obj: any, path: string, value: any) {
    const parts = path.split('.');
    let cur = obj;
    for (let i = 0; i < parts.length - 1; i++) {
      const key = parts[i];
      if (cur[key] == null) cur[key] = /^\d+$/.test(parts[i + 1]) ? [] : {};
      cur = cur[key];
    }
    cur[parts[parts.length - 1]] = value;
  }

  function coerceCoordsField(obj: any, base: string) {
    // collapse "coordinates.0"/"coordinates.1" array writes into a real tuple or undefined
    if (Array.isArray(obj[base])) {
      const [a, b] = obj[base];
      if ((a === '' || a == null) && (b === '' || b == null)) {
        obj[base] = undefined;
      } else {
        obj[base] = [Number(a) || 0, Number(b) || 0];
      }
    }
  }

  root.addEventListener('input', (e) => {
    const t = e.target as HTMLInputElement | HTMLTextAreaElement | HTMLSelectElement;
    const blockIdx = t.getAttribute('data-block');
    const promptIdx = t.getAttribute('data-prompt');
    const trackIdx = t.getAttribute('data-track');
    const phenIdx = t.getAttribute('data-phen');
    const statName = t.getAttribute('data-stat');
    const listName = t.getAttribute('data-list');
    const field = t.getAttribute('data-field');

    if (blockIdx !== null && field) {
      const b = doc.blocks[Number(blockIdx)];
      const value = t.type === 'number' ? Number(t.value) : t.value;
      if (promptIdx !== null) {
        (b.prompts[Number(promptIdx)] as any)[field] = t.value;
      } else if (trackIdx !== null) {
        (b.playlist[Number(trackIdx)] as any)[field] = t.value;
      } else if (field.startsWith('caller_coords.')) {
        if (!Array.isArray((b as any).caller_coords)) (b as any).caller_coords = ['', ''];
        (b as any).caller_coords[Number(field.split('.')[1])] = t.value;
        coerceCoordsField(b, 'caller_coords');
      } else {
        (b as any)[field] = value;
      }
      return;
    }

    if (phenIdx !== null && field) {
      const p = doc.phenomena_log[Number(phenIdx)];
      if (field === 'locations' || field === 'tags') {
        (p as any)[field] = t.value.split(',').map(s => s.trim()).filter(Boolean);
      } else if (field.startsWith('coords.')) {
        if (!Array.isArray((p as any).coords)) (p as any).coords = ['', ''];
        (p as any).coords[Number(field.split('.')[1])] = t.value;
        coerceCoordsField(p, 'coords');
      } else {
        (p as any)[field] = t.value;
      }
      return;
    }

    if (statName) {
      const value = t.type === 'number' ? Number(t.value) : t.value;
      (doc.session_stats as any)[statName] = value;
      return;
    }

    if (listName === 'related_sessions') {
      doc.related_sessions = t.value.split(',').map(s => Number(s.trim())).filter(n => Number.isFinite(n) && t.value.trim() !== '');
      return;
    }
    if (listName) {
      (doc as any)[listName] = t.value.split(',').map(s => s.trim()).filter(Boolean);
      return;
    }

    if (field) {
      const value = t.type === 'number' ? Number(t.value) : t.value;
      if (field.startsWith('coordinates.')) {
        if (!Array.isArray((doc as any).coordinates)) (doc as any).coordinates = ['', ''];
        (doc as any).coordinates[Number(field.split('.')[1])] = t.value;
        coerceCoordsField(doc, 'coordinates');
      } else {
        (doc as any)[field] = value;
      }
    }
  });

  root.addEventListener('click', (e) => {
    const t = e.target as HTMLElement;
    const action = t.getAttribute('data-action');
    if (!action) return;
    const blockIdx = t.getAttribute('data-block');
    const promptIdx = t.getAttribute('data-prompt');
    const trackIdx = t.getAttribute('data-track');
    const phenIdx = t.getAttribute('data-phen');

    if (action === 'add-block') doc.blocks.push(emptyBlock());
    else if (action === 'remove-block') doc.blocks.splice(Number(blockIdx), 1);
    else if (action === 'add-prompt') doc.blocks[Number(blockIdx)].prompts.push(emptyPrompt());
    else if (action === 'remove-prompt') doc.blocks[Number(blockIdx)].prompts.splice(Number(promptIdx), 1);
    else if (action === 'add-track') doc.blocks[Number(blockIdx)].playlist.push(emptyTrack());
    else if (action === 'remove-track') doc.blocks[Number(blockIdx)].playlist.splice(Number(trackIdx), 1);
    else if (action === 'add-phen') doc.phenomena_log.push(emptyPhenomenon());
    else if (action === 'remove-phen') doc.phenomena_log.splice(Number(phenIdx), 1);
    else if (action === 'roll-block') {
      if (!rollState) rollState = initRun(doc.veil_intensity || 3);
      const result = rollBlockMechanics(rollState);
      const b = doc.blocks[Number(blockIdx)];
      b.prompts = result.prompts.map(p => ({ card: p.card, tone: p.tone }));
      b.caller_type = result.caller.type === 'none' ? 'none' : result.caller.type;
      b.caller_card = result.caller.card ?? '';
      b.caller_card_meaning = result.caller.phrase ?? '';
      doc.veil_intensity = result.veilIntensityAfter;
      doc.veil_status = veilStatusFor(result.veilIntensityAfter);
    } else {
      return;
    }
    render();
  });

  document.getElementById('btn-new')!.addEventListener('click', () => {
    doc = defaultSession();
    rollState = null;
    document.getElementById('output-section')!.setAttribute('hidden', '');
    render();
  });

  document.getElementById('btn-recalc')!.addEventListener('click', () => {
    recalcStatsFromBlocks(doc);
    render();
  });

  document.getElementById('btn-generate')!.addEventListener('click', () => {
    const text = buildSessionMarkdown(doc);
    (document.getElementById('output-text') as HTMLTextAreaElement).value = text;
    document.getElementById('output-section')!.removeAttribute('hidden');
  });

  document.getElementById('f-upload')!.addEventListener('change', async (e) => {
    const input = e.target as HTMLInputElement;
    const file = input.files?.[0];
    if (!file) return;
    const text = await file.text();
    doc = parseSessionMarkdown(text);
    rollState = null;
    document.getElementById('output-section')!.setAttribute('hidden', '');
    render();
    input.value = '';
  });

  document.getElementById('btn-copy')!.addEventListener('click', async () => {
    const ta = document.getElementById('output-text') as HTMLTextAreaElement;
    await navigator.clipboard.writeText(ta.value);
  });

  document.getElementById('btn-download')!.addEventListener('click', () => {
    const ta = document.getElementById('output-text') as HTMLTextAreaElement;
    const blob = new Blob([ta.value], { type: 'text/markdown' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = `WBPR-S${String(doc.session).padStart(2, '0')}.md`;
    a.click();
    URL.revokeObjectURL(url);
  });

  render();
</script>
