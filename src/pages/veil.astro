---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import { buildPhenomenaIndex } from '../utils/phenomenaIndex';

const allSessions = await getCollection('sessions');
const sortedSessions = [...allSessions].sort(
  (a, b) => new Date(a.data.date).getTime() - new Date(b.data.date).getTime()
);

const phenomenaIndex = await buildPhenomenaIndex();
const base = import.meta.env.BASE_URL;

// --- SVG Chart ---
const SVG_W = 1000;
const SVG_H = 280;
const M = { top: 30, right: 40, bottom: 52, left: 48 };
const chartW = SVG_W - M.left - M.right;
const chartH = SVG_H - M.top - M.bottom;

const dates = sortedSessions.map(s => new Date(s.data.date).getTime());
const dateMin = dates[0];
const dateMax = dates[dates.length - 1];
const dateRange = dateMax - dateMin;

function xPos(dateStr: string): number {
  return M.left + ((new Date(dateStr).getTime() - dateMin) / dateRange) * chartW;
}

function yPos(intensity: number): number {
  return M.top + chartH - ((intensity - 1) / 9) * chartH;
}

const dawnColourMap: Record<string, string> = {
  'Grey-blue (clean)': '#8899aa',
  'Grey (estimated — clean)': '#888888',
  'Yellow — faint, at the eastern edge only': '#d4c274',
};

const pts = sortedSessions.map(s => ({
  x: xPos(s.data.date),
  y: yPos(s.data.veil_intensity),
  session: s.data.session,
  slug: s.id.replace(/\.md$/, ''),
  intensity: s.data.veil_intensity,
  veilStatus: s.data.veil_status,
  date: s.data.date,
  dawnHex: dawnColourMap[s.data.session_stats?.dawn_colour ?? ''] ?? null,
}));

const linePath = pts.map(p => `${p.x.toFixed(1)},${p.y.toFixed(1)}`).join(' ');
const baseY = M.top + chartH;
const areaPath =
  pts.map(p => `${p.x.toFixed(1)},${p.y.toFixed(1)}`).join(' ') +
  ` ${pts[pts.length - 1].x.toFixed(1)},${baseY} ${pts[0].x.toFixed(1)},${baseY}`;

const yTicks = [1, 3, 5, 7, 10];
// gap line falls between S04 and S05
const gapX = ((pts[3].x + pts[4].x) / 2).toFixed(1);

// --- Phenomena Matrix ---
const matrixLookup = new Map<string, Map<number, string>>();
for (const [key, record] of phenomenaIndex) {
  const m = new Map<number, string>();
  for (const entry of record.entries) m.set(entry.sessionNumber, entry.status);
  matrixLookup.set(key, m);
}

const phenomenaRows = [...phenomenaIndex.values()].sort((a, b) =>
  Math.min(...a.entries.map(e => e.sessionNumber)) -
  Math.min(...b.entries.map(e => e.sessionNumber))
);

const sessionNumbers = sortedSessions.map(s => s.data.session);

const sessionSlugMap = new Map<number, string>();
for (const s of sortedSessions) {
  sessionSlugMap.set(s.data.session, s.id.replace(/\.md$/, ''));
}

function sessionLabel(n: number) {
  return `S${String(n).padStart(2, '0')}`;
}

function shortDate(dateStr: string) {
  return new Date(dateStr).toLocaleDateString('en-US', { month: 'short', year: '2-digit' });
}
---

<Base title="The Veil Record" description="Veil intensity and phenomena tracking across all WBPR sessions.">

  <div class="container">
    <header class="page-header">
      <div class="eyebrow mono">WBPR 1680 AM · Veil Monitoring Log</div>
      <h1>The Veil Record</h1>
      <p class="page-header__sub">
        The veil thins at certain hours, and the chart does not lie.
        Transmissions logged as they were received. The gaps speak too.
      </p>
    </header>
  </div>

  <!-- Chart: wide container -->
  <div class="container--wide">
    <section class="chart-section">
      <h2 class="section-label mono">Veil Intensity</h2>
      <div class="chart-wrap">
        <svg
          viewBox={`0 0 ${SVG_W} ${SVG_H}`}
          width="100%"
          role="img"
          aria-label="Veil intensity across all eight sessions. Sessions 1–4 cluster in late 1973; a long gap precedes sessions 5–8 in 1974–1975."
          xmlns="http://www.w3.org/2000/svg"
          class="veil-chart"
        >
          <!-- Area fill -->
          <polygon points={areaPath} class="chart-area" />

          <!-- Y-axis grid lines -->
          {yTicks.map(v => (
            <line
              x1={M.left} y1={yPos(v).toFixed(1)}
              x2={M.left + chartW} y2={yPos(v).toFixed(1)}
              class="chart-grid"
            />
          ))}

          <!-- Gap annotation -->
          <line
            x1={gapX} y1={M.top}
            x2={gapX} y2={M.top + chartH}
            class="chart-gap-line"
          />
          <text x={gapX} y={M.top - 10} class="chart-gap-label" text-anchor="middle">
            — silence —
          </text>

          <!-- Connecting line -->
          <polyline points={linePath} class="chart-line" />

          <!-- Y-axis labels -->
          {yTicks.map(v => (
            <text
              x={M.left - 8} y={(yPos(v) + 4).toFixed(1)}
              class="chart-axis-label" text-anchor="end"
            >
              {v}
            </text>
          ))}

          <!-- Y-axis title -->
          <text
            x={M.left - 36} y={(M.top + chartH / 2).toFixed(1)}
            class="chart-axis-title"
            text-anchor="middle"
            transform={`rotate(-90, ${M.left - 36}, ${M.top + chartH / 2})`}
          >
            INTENSITY
          </text>

          <!-- Session dots + labels -->
          {pts.map(p => (
            <a href={`${base}sessions/${p.slug}`} class="chart-node">
              <title>S{String(p.session).padStart(2,'0')} — {p.date} — {p.veilStatus} {p.intensity}/10</title>
              <circle
                cx={p.x.toFixed(1)} cy={p.y.toFixed(1)}
                r="6"
                class={`chart-dot chart-dot--${p.veilStatus.toLowerCase()}`}
              />
              <text
                x={p.x.toFixed(1)} y={(M.top + chartH + 18).toFixed(1)}
                class="chart-session-label" text-anchor="middle"
              >
                {sessionLabel(p.session)}
              </text>
              {p.dawnHex && (
                <rect
                  x={(p.x - 5).toFixed(1)} y={(M.top + chartH + 28).toFixed(1)}
                  width="10" height="4"
                  fill={p.dawnHex}
                  rx="1"
                  opacity="0.65"
                />
              )}
            </a>
          ))}
        </svg>

        <div class="chart-legend">
          <span class="chart-legend__item">
            <span class="chart-legend__dot chart-legend__dot--thin"></span>
            <span class="mono">Thin</span>
          </span>
          <span class="chart-legend__item">
            <span class="chart-legend__dot chart-legend__dot--normal"></span>
            <span class="mono">Normal</span>
          </span>
          <span class="chart-legend__item">
            <span class="chart-legend__swatch"></span>
            <span class="mono">Dawn colour</span>
          </span>
        </div>
      </div>
    </section>
  </div>

  <div class="container">

    <!-- Quick Reference Strip -->
    <section class="quick-ref-section">
      <h2 class="section-label mono">Session Quick Reference</h2>
      <div class="scroll-nav">
        <button class="scroll-btn" id="qrc-left" aria-label="Scroll left">&#x2039;</button>
        <div class="scroll-track" id="qrc-track">
        <div class="quick-ref-strip">
          {sortedSessions.map(s => {
            const d = s.data;
            const slug = s.id.replace(/\.md$/, '');
            return (
              <a href={`${base}sessions/${slug}`} class="quick-ref-card">
                <div class="qrc-session mono">{sessionLabel(d.session)}</div>
                <div class="qrc-date mono">{shortDate(d.date)}</div>
                <div class={`qrc-veil veil-badge veil-badge--${d.veil_status.toLowerCase()}`}>
                  {d.veil_status}
                </div>
                <div class="qrc-intensity mono">
                  {d.veil_intensity}<span class="qrc-intensity-max">/10</span>
                </div>
                <div class="qrc-callers mono">{d.callers} caller{d.callers !== 1 ? 's' : ''}</div>
                {d.session_stats?.veil_at_close && (
                  <div class="qrc-close mono">{d.session_stats.veil_at_close}</div>
                )}
              </a>
            );
          })}
        </div>
        </div>
        <button class="scroll-btn" id="qrc-right" aria-label="Scroll right">&#x203a;</button>
      </div>
    </section>

    <!-- Phenomena Emergence Matrix -->
    <section class="matrix-section">
      <h2 class="section-label mono">Emergence Matrix</h2>
      <p class="matrix-desc">
        Each phenomenon tracked across sessions. Colour indicates status at time of observation.
      </p>
      <div class="matrix-legend">
        {(['New','Active','Escalating','Resolved','Dormant'] as const).map(s => (
          <span class="matrix-legend__item">
            <span class={`matrix-dot matrix-dot--${s.toLowerCase()}`} />
            <span class="mono">{s}</span>
          </span>
        ))}
      </div>
      <div class="scroll-nav">
        <button class="scroll-btn" id="matrix-left" aria-label="Scroll left">&#x2039;</button>
        <div class="scroll-track" id="matrix-track">
        <table class="phenomena-matrix">
          <thead>
            <tr>
              <th class="matrix-name-col">Phenomenon</th>
              {sessionNumbers.map(n => (
                <th class="matrix-session-col">
                  <a href={`${base}sessions/${sessionSlugMap.get(n)}`}>
                    {sessionLabel(n)}
                  </a>
                </th>
              ))}
            </tr>
          </thead>
          <tbody>
            {phenomenaRows.map(p => (
              <tr>
                <td class="matrix-name">
                  <a href={`${base}phenomena/${p.key}`}>{p.name}</a>
                </td>
                {sessionNumbers.map(n => {
                  const status = matrixLookup.get(p.key)?.get(n);
                  return (
                    <td class="matrix-cell">
                      {status && (
                        <span
                          class={`matrix-dot matrix-dot--${status.toLowerCase()}`}
                          title={status}
                        />
                      )}
                    </td>
                  );
                })}
              </tr>
            ))}
          </tbody>
        </table>
        </div>
        <button class="scroll-btn" id="matrix-right" aria-label="Scroll right">&#x203a;</button>
      </div>
    </section>

  </div>
</Base>

<style>
  /* ---- Page header ---- */

  .page-header {
    padding: var(--space-2xl) 0 var(--space-xl);
    border-bottom: 1px solid var(--color-border);
    margin-bottom: var(--space-2xl);
  }

  .eyebrow {
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-accent-dim);
    margin-bottom: var(--space-md);
  }

  .page-header h1 {
    font-size: 2.2rem;
    margin-bottom: var(--space-md);
  }

  .page-header__sub {
    font-size: 1rem;
    color: var(--color-text-muted);
    max-width: 560px;
    line-height: 1.75;
    margin: 0;
  }

  /* ---- Section labels ---- */

  .section-label {
    font-size: 0.65rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-text-dim);
    margin-bottom: var(--space-lg);
    font-weight: 400;
  }

  /* ---- Chart ---- */

  .chart-section {
    margin-bottom: var(--space-2xl);
  }

  .chart-wrap {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .veil-chart {
    display: block;
    overflow: visible;
  }

  /* SVG element styles — using :global because Astro scoping
     can be inconsistent for SVG child elements */
  :global(.chart-area) {
    fill: #4a6a8a;
    opacity: 0.08;
  }

  :global(.chart-grid) {
    stroke: var(--color-border);
    stroke-width: 1;
  }

  :global(.chart-line) {
    fill: none;
    stroke: #4a6a8a;
    stroke-width: 2;
    stroke-linejoin: round;
    stroke-linecap: round;
  }

  :global(.chart-gap-line) {
    stroke: var(--color-border);
    stroke-width: 1;
    stroke-dasharray: 4 4;
  }

  :global(.chart-gap-label) {
    font-family: 'JetBrains Mono', 'Courier New', monospace;
    font-size: 9px;
    fill: var(--color-text-dim);
    letter-spacing: 0.06em;
  }

  :global(.chart-axis-label) {
    font-family: 'JetBrains Mono', 'Courier New', monospace;
    font-size: 10px;
    fill: var(--color-text-dim);
  }

  :global(.chart-axis-title) {
    font-family: 'JetBrains Mono', 'Courier New', monospace;
    font-size: 8px;
    letter-spacing: 0.1em;
    fill: var(--color-text-dim);
  }

  :global(.chart-session-label) {
    font-family: 'JetBrains Mono', 'Courier New', monospace;
    font-size: 10px;
    fill: var(--color-text-dim);
  }

  :global(.chart-dot) {
    stroke-width: 2;
    fill: #0a0a0a;
    transition: fill 150ms ease;
  }

  :global(.chart-dot--thin)   { stroke: #4a6a8a; }
  :global(.chart-dot--normal) { stroke: #6a5a3a; }
  :global(.chart-dot--thick)  { stroke: #7a3a3a; }

  :global(.chart-node:hover .chart-dot) {
    fill: #4a6a8a;
  }

  :global(.chart-node:hover .chart-session-label) {
    fill: #d4a574;
  }

  .chart-legend {
    display: flex;
    gap: var(--space-lg);
    align-items: center;
    padding: var(--space-sm) 0;
  }

  .chart-legend__item {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
    font-size: 0.65rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-text-dim);
  }

  .chart-legend__dot {
    display: inline-block;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    border: 2px solid;
    background: var(--color-bg);
  }

  .chart-legend__dot--thin   { border-color: #4a6a8a; }
  .chart-legend__dot--normal { border-color: #6a5a3a; }

  .chart-legend__swatch {
    display: inline-block;
    width: 12px;
    height: 5px;
    border-radius: 1px;
    background: linear-gradient(to right, #8899aa, #d4c274);
    opacity: 0.65;
  }

  /* ---- Scroll nav (shared by quick-ref and matrix) ---- */

  .scroll-nav {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
  }

  .scroll-track {
    flex: 1;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    /* hide native scrollbar */
    scrollbar-width: none;
  }

  .scroll-track::-webkit-scrollbar {
    display: none;
  }

  .scroll-btn {
    flex-shrink: 0;
    background: none;
    border: none;
    color: var(--color-accent-dim);
    font-family: var(--font-mono);
    font-size: 1.6rem;
    line-height: 1;
    cursor: pointer;
    padding: 0 2px;
    transition: color var(--transition), opacity var(--transition);
    user-select: none;
  }

  .scroll-btn:hover {
    color: var(--color-accent);
  }

  .scroll-btn--hidden {
    opacity: 0;
    pointer-events: none;
  }

  /* ---- Quick Reference Strip ---- */

  .quick-ref-section {
    margin-bottom: var(--space-2xl);
  }

  .quick-ref-strip {
    display: flex;
    gap: var(--space-sm);
    min-width: max-content;
  }

  .quick-ref-card {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: var(--space-md);
    min-width: 112px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-surface);
    text-decoration: none;
    transition: border-color var(--transition), background var(--transition);
  }

  .quick-ref-card:hover {
    border-color: var(--color-accent-dim);
    background: var(--color-surface-raised);
  }

  .qrc-session {
    font-size: 0.8rem;
    color: var(--color-accent);
    letter-spacing: 0.1em;
  }

  .qrc-date {
    font-size: 0.66rem;
    color: var(--color-text-dim);
    letter-spacing: 0.04em;
  }

  .qrc-veil {
    align-self: flex-start;
    margin: 2px 0;
  }

  .qrc-intensity {
    font-size: 1.05rem;
    color: #4a6a8a;
    letter-spacing: -0.02em;
    line-height: 1;
    margin-top: 2px;
  }

  .qrc-intensity-max {
    font-size: 0.6rem;
    color: var(--color-text-dim);
  }

  .qrc-callers {
    font-size: 0.63rem;
    color: var(--color-text-dim);
    letter-spacing: 0.02em;
  }

  .qrc-close {
    font-size: 0.6rem;
    color: var(--color-text-dim);
    letter-spacing: 0.02em;
    border-top: 1px solid var(--color-border);
    padding-top: 5px;
    margin-top: 3px;
    line-height: 1.4;
  }

  /* ---- Phenomena Matrix ---- */

  .matrix-section {
    margin-bottom: var(--space-2xl);
  }

  .matrix-desc {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    margin-bottom: var(--space-md);
  }

  .matrix-legend {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-md);
    margin-bottom: var(--space-lg);
  }

  .matrix-legend__item {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
    font-size: 0.65rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-text-dim);
  }

  .phenomena-matrix {
    border-collapse: collapse;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    min-width: 580px;
    width: 100%;
  }

  .phenomena-matrix th,
  .phenomena-matrix td {
    padding: 5px var(--space-sm);
    border-bottom: 1px solid var(--color-border-dim);
    vertical-align: middle;
  }

  .matrix-name-col {
    text-align: left;
    min-width: 190px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    font-size: 0.62rem;
    color: var(--color-text-dim);
  }

  .matrix-session-col {
    text-align: center;
    min-width: 42px;
  }

  .matrix-session-col a {
    color: var(--color-text-dim);
    letter-spacing: 0.08em;
    font-size: 0.68rem;
  }

  .matrix-session-col a:hover {
    color: var(--color-accent);
  }

  .matrix-name {
    text-align: left;
    padding-right: var(--space-md);
  }

  .matrix-name a {
    font-family: var(--font-serif);
    font-size: 0.85rem;
    color: var(--color-text-muted);
    text-decoration: none;
  }

  .matrix-name a:hover {
    color: var(--color-accent);
  }

  .matrix-cell {
    text-align: center;
  }

  .matrix-dot {
    display: inline-block;
    width: 10px;
    height: 10px;
    border-radius: 2px;
    cursor: default;
  }

  .matrix-dot--new        { background: #5a7a9a; }
  .matrix-dot--active     { background: #8a7a4a; }
  .matrix-dot--escalating { background: #c0622a; }
  .matrix-dot--resolved   { background: #4a7a4a; }
  .matrix-dot--dormant    { background: #4a4a4a; }

  @media (max-width: 600px) {
    .page-header h1 { font-size: 1.8rem; }
    .chart-legend { flex-wrap: wrap; gap: var(--space-md); }
  }
</style>

<script>
  function setupScrollNav(trackId: string, leftId: string, rightId: string, amount: number) {
    const track = document.getElementById(trackId) as HTMLElement | null;
    const leftBtn = document.getElementById(leftId) as HTMLButtonElement | null;
    const rightBtn = document.getElementById(rightId) as HTMLButtonElement | null;
    if (!track || !leftBtn || !rightBtn) return;

    function update() {
      const canScroll = track.scrollWidth > track.clientWidth + 1;
      const atStart = track.scrollLeft <= 1;
      const atEnd = track.scrollLeft >= track.scrollWidth - track.clientWidth - 1;
      leftBtn.classList.toggle('scroll-btn--hidden', !canScroll || atStart);
      rightBtn.classList.toggle('scroll-btn--hidden', !canScroll || atEnd);
    }

    leftBtn.addEventListener('click', () => {
      track.scrollBy({ left: -amount, behavior: 'smooth' });
    });

    rightBtn.addEventListener('click', () => {
      track.scrollBy({ left: amount, behavior: 'smooth' });
    });

    track.addEventListener('scroll', update, { passive: true });
    window.addEventListener('resize', update, { passive: true });
    update();
  }

  setupScrollNav('qrc-track', 'qrc-left', 'qrc-right', 240);
  setupScrollNav('matrix-track', 'matrix-left', 'matrix-right', 300);
</script>
