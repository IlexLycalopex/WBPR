---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';

const allSessions = await getCollection('sessions');
const sorted = [...allSessions].sort(
  (a, b) => new Date(a.data.date).getTime() - new Date(b.data.date).getTime()
);
const base = import.meta.env.BASE_URL;

// ─── Geographic projection ────────────────────────────────────────────────────
// Covers the northern Montana / Highway 2 corridor.
const GEO = { minLat: 47.4, maxLat: 49.2, minLon: -116.2, maxLon: -104.2 };
const VB = { w: 1060, h: 350, px: 50, py: 35 };

function projX(lon: number): number {
  return VB.px + ((lon - GEO.minLon) / (GEO.maxLon - GEO.minLon)) * (VB.w - 2 * VB.px);
}
function projY(lat: number): number {
  return VB.h - VB.py - ((lat - GEO.minLat) / (GEO.maxLat - GEO.minLat)) * (VB.h - 2 * VB.py);
}
function proj(coords: [number, number]): [number, number] {
  return [projX(coords[1]), projY(coords[0])];
}

// ─── Fixed geography ──────────────────────────────────────────────────────────
const LOOKOUT: [number, number] = [48.20, -112.90];
const [lx, ly] = proj(LOOKOUT);

// Highway 2 waypoints [lat, lon]
const hwy2Points: [number, number][] = [
  [48.72, -115.60], [48.68, -115.00], [48.62, -114.20],
  [48.57, -113.01], // Browning
  [48.63, -112.33], // Cut Bank
  [48.51, -111.86], // Shelby
  [48.43, -110.88], // Chester
  [48.55, -109.68], // Havre
  [48.36, -107.87], // Malta
  [48.20, -106.63], // Glasgow
  [47.85, -105.60],
];
const hwy2Path = hwy2Points.map(p => proj(p).map(n => n.toFixed(1)).join(',')).join(' ');

const towns: { name: string; coords: [number, number]; label?: string }[] = [
  { name: 'Browning',  coords: [48.57, -113.01] },
  { name: 'Cut Bank',  coords: [48.63, -112.33] },
  { name: 'Shelby',    coords: [48.51, -111.86] },
  { name: 'Havre',     coords: [48.55, -109.68] },
  { name: 'Malta',     coords: [48.36, -107.87] },
  { name: 'Glasgow',   coords: [48.20, -106.63] },
];

// ─── Phenomena markers (from content collection) ──────────────────────────────
const phenomenaMap = new Map<string, {
  key: string; name: string; status: string; confidence: string;
  coords: [number, number]; sessions: number[]; latestNotes: string;
}>();

for (const session of sorted) {
  for (const p of session.data.phenomena_log) {
    if (!p.coords) continue;
    if (!phenomenaMap.has(p.key)) {
      phenomenaMap.set(p.key, {
        key: p.key, name: p.name, status: p.status,
        confidence: p.confidence, coords: p.coords,
        sessions: [], latestNotes: p.notes,
      });
    }
    const m = phenomenaMap.get(p.key)!;
    m.status = p.status;
    m.confidence = p.confidence;
    m.latestNotes = p.notes;
    if (!m.sessions.includes(session.data.session)) m.sessions.push(session.data.session);
  }
}
const phenomenaMarkers = [...phenomenaMap.values()];

// ─── Full phenomena data for detail panels ────────────────────────────────────
// Build richer records including all session entries
const phenomenaDetail = new Map<string, {
  key: string; name: string; latestStatus: string; latestConfidence: string;
  coords?: [number, number];
  entries: { session: number; slug: string; date: string; status: string; notes: string; locations: string[] }[];
}>();

for (const session of sorted) {
  const slug = session.id.replace(/\.md$/, '');
  for (const p of session.data.phenomena_log) {
    if (!phenomenaDetail.has(p.key)) {
      phenomenaDetail.set(p.key, {
        key: p.key, name: p.name,
        latestStatus: p.status, latestConfidence: p.confidence,
        coords: p.coords, entries: [],
      });
    }
    const d = phenomenaDetail.get(p.key)!;
    d.latestStatus = p.status;
    d.latestConfidence = p.confidence;
    if (p.coords) d.coords = p.coords;
    d.entries.push({
      session: session.data.session, slug, date: session.data.date,
      status: p.status, notes: p.notes, locations: p.locations,
    });
  }
}

// ─── Caller markers (from content collection) ─────────────────────────────────
const callerMarkers: {
  session: number; slug: string; type: string;
  coords: [number, number]; confidence: string; location: string;
  card: string; cardMeaning: string;
}[] = [];

for (const session of sorted) {
  const slug = session.id.replace(/\.md$/, '');
  for (const block of session.data.blocks) {
    if (!block.caller_coords || block.caller_type === 'none') continue;
    callerMarkers.push({
      session: session.data.session, slug,
      type: block.caller_type,
      coords: block.caller_coords,
      confidence: block.caller_location_confidence ?? 'unknown',
      location: block.caller_location ?? '',
      card: block.caller_card ?? '',
      cardMeaning: block.caller_card_meaning ?? '',
    });
  }
}

// ─── Session list for filter ──────────────────────────────────────────────────
const sessionNumbers = sorted.map(s => s.data.session);

// ─── Unlocated caller count ───────────────────────────────────────────────────
let unlocatedCallers = 0;
for (const session of sorted) {
  for (const block of session.data.blocks) {
    if (block.caller_type !== 'none' && !block.caller_coords) unlocatedCallers++;
  }
}

// ─── Helpers ──────────────────────────────────────────────────────────────────
function sessionLabel(n: number) { return `S${String(n).padStart(2, '0')}`; }
function fmtDate(d: string) {
  return new Date(d).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
}
---

<Base title="Transmission Map" description="Geographic distribution of reported phenomena and caller origins — WBPR 1680 AM">

<div class="map-page">

  <!-- ─── Page header ─── -->
  <div class="map-header container--wide">
    <div class="map-header__left">
      <div class="eyebrow mono">Transmission Map</div>
      <h1>Reported Locations</h1>
      <p>Geographic distribution of phenomena and caller origins, S05–S{String(Math.max(...sessionNumbers)).padStart(2,'0')}. Select a marker to view detail.</p>
    </div>
    <div class="map-header__stats mono">
      <span>{phenomenaMarkers.length} phenomena plotted</span>
      <span>{callerMarkers.length} callers located</span>
      <span>{unlocatedCallers} unlocated</span>
    </div>
  </div>

  <!-- ─── Filter bar ─── -->
  <div class="filter-bar container--wide">
    <div class="filter-group">
      <span class="filter-label mono">Session</span>
      <div class="session-pills" id="session-pills">
        {sessionNumbers.map(n => (
          <button class="pill active" data-session={n}>{sessionLabel(n)}</button>
        ))}
      </div>
    </div>
    <div class="filter-group">
      <span class="filter-label mono">Layers</span>
      <div class="layer-toggles">
        <button class="toggle on" data-layer="phenomena">
          <span class="toggle-dot toggle-dot--phenomena"></span>Phenomena
        </button>
        <button class="toggle on" data-layer="callers">
          <span class="toggle-dot toggle-dot--callers"></span>Callers
        </button>
        <button class="toggle on" data-layer="broadcast">
          <span class="toggle-dot toggle-dot--broadcast"></span>Broadcast range
        </button>
      </div>
    </div>
  </div>

  <!-- ─── Main layout ─── -->
  <div class="map-layout">

    <!-- ─── SVG Map ─── -->
    <div class="map-area" id="map-area">
      <svg
        viewBox={`0 0 ${VB.w} ${VB.h}`}
        preserveAspectRatio="xMidYMid meet"
        id="transmission-svg"
        role="img"
        aria-label="Schematic map of northern Montana showing WBPR broadcast origin and reported phenomena locations along the Highway 2 corridor"
      >
        <!-- Background -->
        <rect width={VB.w} height={VB.h} fill="#070708"/>

        <!-- Dot grid -->
        <defs>
          <pattern id="dot-grid" width="30" height="30" patternUnits="userSpaceOnUse">
            <circle cx="15" cy="15" r="0.6" fill="#151515"/>
          </pattern>
          <filter id="glow-sm">
            <feGaussianBlur stdDeviation="2.5" result="blur"/>
            <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
          </filter>
          <filter id="glow-lg">
            <feGaussianBlur stdDeviation="5" result="blur"/>
            <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
          </filter>
        </defs>
        <rect width={VB.w} height={VB.h} fill="url(#dot-grid)"/>

        <!-- Canadian border -->
        <line
          x1={projX(-116.2).toFixed(1)} y1={projY(49.0).toFixed(1)}
          x2={projX(-104.2).toFixed(1)} y2={projY(49.0).toFixed(1)}
          stroke="#1e1e1e" stroke-width="1" stroke-dasharray="5,5"
        />
        <text
          x={((projX(-116.2) + projX(-104.2)) / 2).toFixed(1)}
          y={(projY(49.0) - 8).toFixed(1)}
          font-family="'JetBrains Mono', monospace" font-size="7"
          fill="#222" letter-spacing="0.22em" text-anchor="middle"
        >CANADA</text>

        <!-- Montana state outline (simplified rectangle + western slope) -->
        <path
          d={`M ${projX(-116.2).toFixed(1)},${projY(49.0).toFixed(1)}
              L ${projX(-104.2).toFixed(1)},${projY(49.0).toFixed(1)}
              L ${projX(-104.04).toFixed(1)},${projY(47.4).toFixed(1)}
              L ${projX(-116.05).toFixed(1)},${projY(47.4).toFixed(1)} Z`}
          fill="none" stroke="#161616" stroke-width="1.5"
        />

        <!-- Mountain silhouette (western Rocky region) -->
        <polygon
          points={`
            ${projX(-116.2).toFixed(1)},${projY(47.4).toFixed(1)}
            ${projX(-116.2).toFixed(1)},${projY(48.85).toFixed(1)}
            ${projX(-115.8).toFixed(1)},${projY(48.70).toFixed(1)}
            ${projX(-115.5).toFixed(1)},${projY(48.80).toFixed(1)}
            ${projX(-115.2).toFixed(1)},${projY(48.55).toFixed(1)}
            ${projX(-114.8).toFixed(1)},${projY(48.65).toFixed(1)}
            ${projX(-114.4).toFixed(1)},${projY(48.40).toFixed(1)}
            ${projX(-114.0).toFixed(1)},${projY(48.50).toFixed(1)}
            ${projX(-113.6).toFixed(1)},${projY(48.30).toFixed(1)}
            ${projX(-113.2).toFixed(1)},${projY(48.20).toFixed(1)}
            ${projX(-113.2).toFixed(1)},${projY(47.4).toFixed(1)}
          `}
          fill="#0c0c0d"
        />

        <!-- Highway 2 — glow -->
        <polyline points={hwy2Path} fill="none" stroke="#d4a574" stroke-width="5" opacity="0.04"/>
        <!-- Highway 2 — line -->
        <polyline points={hwy2Path} fill="none" stroke="#8a6040" stroke-width="1.8" opacity="0.8"/>
        <!-- Highway 2 — label -->
        <text
          x={projX(-110.5).toFixed(1)} y={(projY(48.55) - 8).toFixed(1)}
          font-family="'JetBrains Mono', monospace" font-size="7"
          fill="#4a3820" letter-spacing="0.14em" text-anchor="middle"
        >US ROUTE 2</text>

        <!-- Towns -->
        {towns.map(t => {
          const [tx, ty] = proj(t.coords);
          return (
            <>
              <circle cx={tx.toFixed(1)} cy={ty.toFixed(1)} r="2.5" fill="#242424" stroke="#303030" stroke-width="0.8"/>
              <text
                x={tx.toFixed(1)} y={(ty - 7).toFixed(1)}
                font-family="'JetBrains Mono', monospace" font-size="7"
                fill="#3a3530" letter-spacing="0.05em" text-anchor="middle"
              >{t.name.toUpperCase()}</text>
            </>
          );
        })}

        <!-- ─── Broadcast origin ─── -->
        <g class="layer-broadcast" id="broadcast-layer">
          <!-- Animated rings -->
          <circle cx={lx.toFixed(1)} cy={ly.toFixed(1)} r="8" class="broadcast-ring"/>
          <circle cx={lx.toFixed(1)} cy={ly.toFixed(1)} r="8" class="broadcast-ring broadcast-ring--2"/>
          <circle cx={lx.toFixed(1)} cy={ly.toFixed(1)} r="8" class="broadcast-ring broadcast-ring--3"/>
          <!-- Lookout core -->
          <circle
            cx={lx.toFixed(1)} cy={ly.toFixed(1)} r="6"
            fill="#d4a574" stroke="#0a0a0a" stroke-width="1.5"
            filter="url(#glow-sm)"
            class="lookout-marker"
            data-key="lookout"
          />
          <circle cx={lx.toFixed(1)} cy={ly.toFixed(1)} r="2" fill="#0a0a0a"/>
          <text
            x={lx.toFixed(1)} y={(ly + 16).toFixed(1)}
            font-family="'JetBrains Mono', monospace" font-size="7"
            fill="#8a6040" letter-spacing="0.1em" text-anchor="middle"
          >WBPR · 7,200ft</text>
        </g>

        <!-- ─── Phenomena markers (data-driven) ─── -->
        <g class="layer-phenomena" id="phenomena-layer">
          {phenomenaMarkers.map(m => {
            const [mx, my] = proj(m.coords);
            const statusClass = m.status.toLowerCase();
            // Cluster offset for lookout-co-located phenomena
            const isLookout = m.coords[0] === LOOKOUT[0] && m.coords[1] === LOOKOUT[1];
            return (
              <g
                class={`phenom-marker phenom-marker--${statusClass}`}
                data-key={m.key}
                data-session={m.sessions.join(',')}
                role="button"
                tabindex="0"
                aria-label={`${m.name} — ${m.status}`}
                style={isLookout ? `--offset-x: ${(mx - 12).toFixed(1)}px; --offset-y: ${(my - 12).toFixed(1)}px` : ''}
              >
                {/* Aura */}
                <circle
                  cx={mx.toFixed(1)} cy={my.toFixed(1)}
                  r={isLookout ? '12' : '18'}
                  class={`phenom-aura phenom-aura--${statusClass}`}
                />
                {/* Core */}
                <circle
                  cx={mx.toFixed(1)} cy={my.toFixed(1)} r="6"
                  class={`phenom-core phenom-core--${statusClass}`}
                />
                {/* Label */}
                {!isLookout && (
                  <text
                    x={mx.toFixed(1)} y={(my - 12).toFixed(1)}
                    font-family="'JetBrains Mono', monospace" font-size="7"
                    class={`phenom-label phenom-label--${statusClass}`}
                    text-anchor="middle"
                    pointer-events="none"
                  >{m.name.toUpperCase()}</text>
                )}
              </g>
            );
          })}
        </g>

        <!-- ─── Caller markers (data-driven diamonds) ─── -->
        <g class="layer-callers" id="callers-layer">
          {callerMarkers.map((c, i) => {
            const [cx2, cy2] = proj(c.coords);
            const isDashed = c.confidence === 'approximate';
            return (
              <g
                class={`caller-marker caller-marker--${c.type}`}
                data-index={i}
                data-session={c.session}
                role="button"
                tabindex="0"
                aria-label={`S${String(c.session).padStart(2,'0')} ${c.type} caller — ${c.location || 'location approximate'}`}
              >
                <rect
                  x={(cx2 - 5).toFixed(1)} y={(cy2 - 5).toFixed(1)}
                  width="10" height="10"
                  transform={`rotate(45 ${cx2.toFixed(1)} ${cy2.toFixed(1)})`}
                  fill="none"
                  stroke-width="1.5"
                  stroke-dasharray={isDashed ? '2,2' : 'none'}
                  class={`caller-diamond caller-diamond--${c.type}`}
                />
                <text
                  x={cx2.toFixed(1)} y={(cy2 + 18).toFixed(1)}
                  font-family="'JetBrains Mono', monospace" font-size="6.5"
                  fill="#3a3530" letter-spacing="0.04em" text-anchor="middle"
                  pointer-events="none"
                >{sessionLabel(c.session)}</text>
              </g>
            );
          })}
        </g>

        <!-- Coord grid (faint lat/lon lines) -->
        {[48.0, 48.5, 49.0].map(lat => (
          <line
            x1={VB.px} y1={projY(lat).toFixed(1)}
            x2={(VB.w - VB.px)} y2={projY(lat).toFixed(1)}
            stroke="#111" stroke-width="0.5" stroke-dasharray="1,8"
          />
        ))}

        <!-- South label -->
        <text
          x={(VB.w / 2).toFixed(1)} y={(VB.h - 8).toFixed(1)}
          font-family="'JetBrains Mono', monospace" font-size="6.5"
          fill="#1e1e1e" letter-spacing="0.14em" text-anchor="middle"
        >NORTHERN MONTANA CORRIDOR</text>
      </svg>

      <!-- Coordinate readout -->
      <div class="map-coords mono" id="map-coords">48.5° N · 111.8° W</div>
    </div>

    <!-- ─── Detail panel ─── -->
    <aside class="detail-panel" id="detail-panel">

      <!-- Empty state -->
      <div class="detail-empty" id="detail-empty">
        <span class="mono">Select a marker</span>
      </div>

      <!-- Phenomenon panes (pre-rendered, hidden until selected) -->
      {[...phenomenaDetail.values()].map(p => (
        <div class="detail-pane" id={`pane-${p.key}`} hidden data-key={p.key}>

          <button
            class="scroll-btn scroll-btn--vert scroll-btn--up"
            data-track={`track-${p.key}`}
            aria-label="Scroll up"
          >&#x2039;</button>

          <div class="detail-track" id={`track-${p.key}`}>
            <div class="detail-content">

              <div class="detail-header">
                <div class="detail-badges">
                  <span class={`badge badge--${p.latestStatus.toLowerCase()}`}>{p.latestStatus}</span>
                  <span class={`badge badge--${p.latestConfidence.toLowerCase()}`}>{p.latestConfidence}</span>
                  {p.coords && <span class="badge badge--geo">Mapped</span>}
                </div>
                <h2 class="detail-name">{p.name}</h2>
                {p.entries[0]?.locations[0] && (
                  <p class="detail-location mono">{p.entries[p.entries.length - 1].locations[0]}</p>
                )}
              </div>

              <div class="detail-section">
                <div class="detail-section-label mono">Sessions</div>
                <div class="detail-session-refs">
                  {p.entries.map(e => (
                    <a href={`${base}sessions/${e.slug}`} class="session-ref mono">
                      {sessionLabel(e.session)} · {fmtDate(e.date)}
                    </a>
                  ))}
                </div>
              </div>

              <div class="detail-section">
                <div class="detail-section-label mono">Most recent note</div>
                <p class="detail-notes">{p.entries[p.entries.length - 1].notes}</p>
              </div>

              {p.entries.length > 1 && (
                <div class="detail-section">
                  <div class="detail-section-label mono">History · {p.entries.length} sessions</div>
                  <div class="detail-history">
                    {p.entries.map(e => (
                      <div class="history-entry">
                        <span class={`history-status mono badge badge--${e.status.toLowerCase()}`}>{e.status}</span>
                        <a href={`${base}sessions/${e.slug}`} class="history-session mono">{sessionLabel(e.session)}</a>
                        <p class="history-notes">{e.notes}</p>
                      </div>
                    ))}
                  </div>
                </div>
              )}

              <div class="detail-nav-links">
                <a href={`${base}phenomena/${p.key}`} class="detail-link mono">
                  Full record →
                </a>
              </div>

            </div>
          </div>

          <button
            class="scroll-btn scroll-btn--vert scroll-btn--down"
            data-track={`track-${p.key}`}
            aria-label="Scroll down"
          >&#x203a;</button>

        </div>
      ))}

      <!-- Caller panes -->
      {callerMarkers.map((c, i) => (
        <div class="detail-pane" id={`pane-caller-${i}`} hidden data-index={i}>

          <button
            class="scroll-btn scroll-btn--vert scroll-btn--up"
            data-track={`track-caller-${i}`}
            aria-label="Scroll up"
          >&#x2039;</button>

          <div class="detail-track" id={`track-caller-${i}`}>
            <div class="detail-content">

              <div class="detail-header">
                <div class="detail-badges">
                  <span class={`badge badge--caller-${c.type}`}>{c.type}</span>
                  <span class={`badge badge--${c.confidence}`}>{c.confidence}</span>
                </div>
                <h2 class="detail-name">{sessionLabel(c.session)} Caller</h2>
                {c.location && <p class="detail-location mono">{c.location}</p>}
              </div>

              {c.card && (
                <div class="detail-section">
                  <div class="detail-section-label mono">Card drawn</div>
                  <p class="detail-notes">{c.card} — <em>{c.cardMeaning}</em></p>
                </div>
              )}

              <div class="detail-nav-links">
                <a href={`${base}sessions/${c.slug}`} class="detail-link mono">
                  Session {sessionLabel(c.session)} →
                </a>
              </div>

            </div>
          </div>

          <button
            class="scroll-btn scroll-btn--vert scroll-btn--down"
            data-track={`track-caller-${i}`}
            aria-label="Scroll down"
          >&#x203a;</button>

        </div>
      ))}

    </aside>
  </div>

  <!-- ─── Legend ─── -->
  <div class="map-legend container--wide">
    <div class="legend-group">
      <span class="legend-label mono">Phenomena</span>
      <div class="legend-items">
        <div class="legend-item"><span class="legend-dot legend-dot--escalating"></span><span class="mono">Escalating</span></div>
        <div class="legend-item"><span class="legend-dot legend-dot--active"></span><span class="mono">Active</span></div>
        <div class="legend-item"><span class="legend-dot legend-dot--new"></span><span class="mono">New</span></div>
        <div class="legend-item"><span class="legend-dot legend-dot--lookout"></span><span class="mono">WBPR lookout</span></div>
      </div>
    </div>
    <div class="legend-group">
      <span class="legend-label mono">Callers</span>
      <div class="legend-items">
        <div class="legend-item"><span class="legend-diamond legend-diamond--phenomenon"></span><span class="mono">Phenomenon</span></div>
        <div class="legend-item"><span class="legend-diamond legend-diamond--standard"></span><span class="mono">Standard</span></div>
        <div class="legend-item"><span class="legend-diamond legend-diamond--approximate"></span><span class="mono">Approximate location</span></div>
      </div>
    </div>
    <div class="legend-group legend-group--right">
      <span class="legend-label mono">S05–S{String(Math.max(...sessionNumbers)).padStart(2,'0')} · 1974–75 · Northern Montana</span>
    </div>
  </div>

</div>
</Base>

<style>
  /* ─── Page layout ─── */
  .map-page {
    display: flex;
    flex-direction: column;
    height: calc(100vh - 60px); /* subtract site header */
  }

  .map-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 2rem;
    padding: 1.25rem 2rem 1rem;
    border-bottom: 1px solid var(--color-border-dim);
    flex-shrink: 0;
  }
  .map-header h1 {
    font-size: 1.5rem;
    margin-bottom: 0.2rem;
  }
  .map-header p {
    font-size: 0.82rem;
    color: var(--color-text-muted);
    margin: 0;
  }
  .eyebrow {
    font-size: 0.58rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-accent-dim);
    margin-bottom: 0.3rem;
  }
  .map-header__stats {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.2rem;
    font-size: 0.6rem;
    letter-spacing: 0.08em;
    color: var(--color-text-dim);
    flex-shrink: 0;
    padding-bottom: 0.1rem;
  }

  /* ─── Filter bar ─── */
  .filter-bar {
    display: flex;
    gap: 2rem;
    align-items: center;
    padding: 0.6rem 2rem;
    border-bottom: 1px solid var(--color-border);
    background: var(--color-surface);
    flex-shrink: 0;
    flex-wrap: wrap;
  }
  .filter-group { display: flex; align-items: center; gap: 0.6rem; }
  .filter-label {
    font-size: 0.58rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-text-dim);
    white-space: nowrap;
  }
  .session-pills { display: flex; gap: 0.25rem; }
  .pill {
    font-family: var(--font-mono);
    font-size: 0.58rem;
    letter-spacing: 0.06em;
    padding: 0.18rem 0.5rem;
    border: 1px solid var(--color-border);
    border-radius: 2px;
    cursor: pointer;
    background: transparent;
    color: var(--color-text-dim);
    transition: all 150ms;
  }
  .pill.active {
    border-color: var(--color-accent-dim);
    color: var(--color-accent);
    background: rgba(212, 165, 116, 0.05);
  }
  .layer-toggles { display: flex; gap: 0.25rem; }
  .toggle {
    font-family: var(--font-mono);
    font-size: 0.58rem;
    letter-spacing: 0.06em;
    padding: 0.18rem 0.5rem;
    border: 1px solid var(--color-border);
    border-radius: 2px;
    cursor: pointer;
    background: transparent;
    color: var(--color-text-muted);
    display: flex;
    align-items: center;
    gap: 0.3rem;
    transition: all 150ms;
  }
  .toggle.on  { border-color: var(--color-border); color: var(--color-text-muted); }
  .toggle.off { opacity: 0.35; }
  .toggle-dot {
    width: 5px; height: 5px; border-radius: 50%; flex-shrink: 0;
  }
  .toggle-dot--phenomena { background: var(--color-status-escalating); }
  .toggle-dot--callers   { background: #c0622a; }
  .toggle-dot--broadcast { background: var(--color-accent-dim); }

  /* ─── Map layout ─── */
  .map-layout {
    display: grid;
    grid-template-columns: 1fr 330px;
    flex: 1;
    min-height: 0;
    overflow: hidden;
  }

  /* ─── SVG map area ─── */
  .map-area {
    position: relative;
    background: #070708;
    border-right: 1px solid var(--color-border);
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .map-area svg {
    width: 100%;
    height: 100%;
    display: block;
  }
  .map-coords {
    position: absolute;
    bottom: 0.6rem;
    left: 0.75rem;
    font-size: 0.55rem;
    letter-spacing: 0.08em;
    color: var(--color-text-dim);
    background: rgba(7,7,8,0.85);
    padding: 0.2rem 0.4rem;
    border-radius: 2px;
    pointer-events: none;
  }

  /* SVG broadcast rings */
  :global(.broadcast-ring) {
    fill: none;
    stroke: var(--color-accent);
    stroke-width: 1;
    opacity: 0;
    animation: broadcast-pulse 4.5s ease-out infinite;
  }
  :global(.broadcast-ring--2) { animation-delay: 1.5s; }
  :global(.broadcast-ring--3) { animation-delay: 3s; }
  @keyframes broadcast-pulse {
    0%   { r: 8;  opacity: 0.45; }
    100% { r: 90; opacity: 0; }
  }

  /* SVG phenomena */
  :global(.phenom-aura) { opacity: 0.1; transition: opacity 200ms; }
  :global(.phenom-aura--escalating) { fill: #c0622a; animation: phenom-pulse 2.8s ease-in-out infinite; }
  :global(.phenom-aura--active)     { fill: #8a7a4a; }
  :global(.phenom-aura--new)        { fill: #5a7a9a; }
  :global(.phenom-aura--dormant)    { fill: #4a4a4a; }
  :global(.phenom-aura--resolved)   { fill: #4a7a4a; }
  @keyframes phenom-pulse {
    0%, 100% { opacity: 0.08; }
    50%       { opacity: 0.20; }
  }
  :global(.phenom-core) { stroke: #0a0a0a; stroke-width: 1.5; transition: filter 200ms; }
  :global(.phenom-core--escalating) { fill: #c0622a; filter: drop-shadow(0 0 3px rgba(192,98,42,0.6)); }
  :global(.phenom-core--active)     { fill: #8a7a4a; filter: drop-shadow(0 0 3px rgba(138,122,74,0.5)); }
  :global(.phenom-core--new)        { fill: #5a7a9a; filter: drop-shadow(0 0 3px rgba(90,122,154,0.5)); }
  :global(.phenom-core--dormant)    { fill: #4a4a4a; }
  :global(.phenom-core--resolved)   { fill: #4a7a4a; }
  :global(.phenom-label--escalating) { fill: #7a3a18; }
  :global(.phenom-label--active)     { fill: #5a4a2a; }
  :global(.phenom-label--new)        { fill: #3a4a5a; }
  :global(.phenom-marker) { cursor: pointer; }
  :global(.phenom-marker:hover .phenom-aura) { opacity: 0.25; }
  :global(.phenom-marker.selected .phenom-core) {
    stroke: var(--color-text) !important;
    stroke-width: 2 !important;
  }
  :global(.phenom-marker.selected .phenom-aura) { opacity: 0.3; }

  /* SVG callers */
  :global(.caller-marker) { cursor: pointer; }
  :global(.caller-diamond--phenomenon) { stroke: #c0622a; }
  :global(.caller-diamond--standard)   { stroke: #5a7a5a; }
  :global(.caller-diamond--emergency)  { stroke: #aa2a2a; }
  :global(.caller-marker:hover .caller-diamond) { stroke-width: 2.5; }
  :global(.caller-marker.selected .caller-diamond) {
    stroke-width: 2.5;
    filter: drop-shadow(0 0 3px rgba(212,165,116,0.4));
  }

  /* ─── Detail panel ─── */
  .detail-panel {
    display: flex;
    flex-direction: column;
    background: var(--color-surface);
    min-height: 0;
    position: relative;
  }
  .detail-empty {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-text-dim);
    font-size: 0.65rem;
    letter-spacing: 0.12em;
  }
  .detail-pane {
    display: flex;
    flex-direction: column;
    height: 100%;
    min-height: 0;
  }

  /* Chevron scroll buttons — vertical variant */
  .scroll-btn {
    flex-shrink: 0;
    background: none;
    border: none;
    color: var(--color-accent-dim);
    font-family: var(--font-mono);
    font-size: 1.5rem;
    line-height: 1;
    cursor: pointer;
    padding: 4px 0;
    transition: color 150ms, opacity 150ms;
    user-select: none;
    display: flex;
    align-items: center;
    justify-content: center;
    border-bottom: 1px solid var(--color-border-dim);
  }
  .scroll-btn:hover { color: var(--color-accent); }
  .scroll-btn--hidden { opacity: 0; pointer-events: none; }
  /* Rotate ‹ and › to become ∧ and ∨ */
  .scroll-btn--vert.scroll-btn--up   { transform: rotate(90deg); border-bottom: 1px solid var(--color-border-dim); border-top: none; }
  .scroll-btn--vert.scroll-btn--down { transform: rotate(90deg); border-top: 1px solid var(--color-border-dim); border-bottom: none; }

  /* Detail content track */
  .detail-track {
    flex: 1;
    overflow-y: auto;
    scrollbar-width: none;
    min-height: 0;
  }
  .detail-track::-webkit-scrollbar { display: none; }

  .detail-content { padding: 1.25rem 1.25rem 1rem; }

  .detail-header {
    border-bottom: 1px solid var(--color-border);
    padding-bottom: 0.9rem;
    margin-bottom: 1rem;
  }
  .detail-badges { display: flex; gap: 0.3rem; flex-wrap: wrap; margin-bottom: 0.5rem; }
  .detail-name {
    font-family: var(--font-serif);
    font-size: 1.2rem;
    font-weight: 500;
    color: var(--color-text);
    margin-bottom: 0.2rem;
    line-height: 1.2;
  }
  .detail-location {
    font-size: 0.6rem;
    letter-spacing: 0.06em;
    color: var(--color-text-dim);
    margin: 0;
  }

  .detail-section { margin-bottom: 1rem; }
  .detail-section-label {
    font-size: 0.55rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-text-dim);
    margin-bottom: 0.4rem;
  }
  .detail-notes {
    font-size: 0.82rem;
    color: var(--color-text-muted);
    line-height: 1.65;
    margin: 0;
  }
  .detail-notes em { color: var(--color-text-dim); font-style: italic; }

  .detail-session-refs { display: flex; flex-direction: column; gap: 0.2rem; }
  .session-ref {
    font-size: 0.62rem;
    letter-spacing: 0.05em;
    color: var(--color-text-dim);
    text-decoration: none;
    padding: 0.2rem 0.4rem;
    border: 1px solid var(--color-border);
    border-radius: 2px;
    transition: border-color 150ms, color 150ms;
    display: block;
  }
  .session-ref:hover { border-color: var(--color-accent-dim); color: var(--color-accent); }

  .detail-history { display: flex; flex-direction: column; gap: 0.75rem; }
  .history-entry { display: flex; flex-direction: column; gap: 0.2rem; }
  .history-session {
    font-size: 0.6rem;
    letter-spacing: 0.06em;
    color: var(--color-accent-dim);
    text-decoration: none;
  }
  .history-session:hover { color: var(--color-accent); }
  .history-notes {
    font-size: 0.78rem;
    color: var(--color-text-dim);
    line-height: 1.55;
    padding-left: 0.5rem;
    border-left: 2px solid var(--color-border);
    margin: 0;
  }
  .history-status { font-size: 0.52rem !important; padding: 0.1rem 0.3rem !important; }

  .detail-nav-links {
    padding-top: 0.75rem;
    border-top: 1px solid var(--color-border);
    margin-top: 0.5rem;
  }
  .detail-link {
    font-size: 0.62rem;
    letter-spacing: 0.06em;
    color: var(--color-text-dim);
    text-decoration: none;
    transition: color 150ms;
  }
  .detail-link:hover { color: var(--color-accent); }

  /* ─── Badges ─── */
  :global(.badge) {
    font-family: var(--font-mono);
    font-size: 0.52rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.13rem 0.4rem;
    border-radius: 2px;
    display: inline-block;
  }
  :global(.badge--escalating) { background: rgba(192,98,42,0.15);  color: #c0622a; border: 1px solid rgba(192,98,42,0.3); }
  :global(.badge--active)     { background: rgba(138,122,74,0.15); color: #8a7a4a; border: 1px solid rgba(138,122,74,0.3); }
  :global(.badge--new)        { background: rgba(90,122,154,0.15); color: #5a7a9a; border: 1px solid rgba(90,122,154,0.3); }
  :global(.badge--resolved)   { background: rgba(74,122,74,0.12);  color: #5a9a5a; border: 1px solid rgba(74,122,74,0.25); }
  :global(.badge--dormant)    { background: rgba(74,74,74,0.15);   color: #7a7a7a; border: 1px solid rgba(74,74,74,0.3); }
  :global(.badge--confirmed)  { background: rgba(74,122,74,0.12);  color: #5a9a5a; border: 1px solid rgba(74,122,74,0.25); }
  :global(.badge--likely)     { background: rgba(74,74,100,0.15);  color: #7a7aaa; border: 1px solid rgba(74,74,100,0.3); }
  :global(.badge--unconfirmed){ background: rgba(74,74,74,0.12);   color: #6a6a6a; border: 1px solid rgba(74,74,74,0.25); }
  :global(.badge--geo)        { background: rgba(90,122,154,0.1);  color: #4a6a8a; border: 1px solid rgba(90,122,154,0.2); }
  :global(.badge--caller-phenomenon) { background: rgba(192,98,42,0.15);  color: #c0622a; border: 1px solid rgba(192,98,42,0.3); }
  :global(.badge--caller-standard)   { background: rgba(74,122,74,0.12);  color: #5a8a5a; border: 1px solid rgba(74,122,74,0.25); }
  :global(.badge--caller-emergency)  { background: rgba(170,42,42,0.15);  color: #aa5a5a; border: 1px solid rgba(170,42,42,0.3); }
  :global(.badge--precise)    { background: rgba(74,122,74,0.1);   color: #4a7a4a; border: 1px solid rgba(74,122,74,0.2); }
  :global(.badge--approximate){ background: rgba(138,122,74,0.12); color: #7a6a3a; border: 1px solid rgba(138,122,74,0.25); }
  :global(.badge--accent-only){ background: rgba(74,74,100,0.12);  color: #5a5a7a; border: 1px solid rgba(74,74,100,0.25); }
  :global(.badge--unknown)    { background: rgba(74,74,74,0.1);    color: #5a5a5a; border: 1px solid rgba(74,74,74,0.2); }

  /* ─── Legend ─── */
  .map-legend {
    border-top: 1px solid var(--color-border);
    background: var(--color-surface);
    padding: 0.5rem 2rem;
    display: flex;
    gap: 2rem;
    align-items: center;
    flex-wrap: wrap;
    flex-shrink: 0;
  }
  .legend-group { display: flex; align-items: center; gap: 0.75rem; }
  .legend-group--right { margin-left: auto; }
  .legend-label {
    font-size: 0.55rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text-dim);
  }
  .legend-items { display: flex; gap: 0.8rem; align-items: center; }
  .legend-item {
    display: flex; align-items: center; gap: 0.3rem;
    font-family: var(--font-mono); font-size: 0.55rem;
    letter-spacing: 0.04em; color: var(--color-text-dim);
  }
  .legend-dot {
    width: 7px; height: 7px; border-radius: 50%; flex-shrink: 0;
  }
  .legend-dot--escalating { background: #c0622a; }
  .legend-dot--active     { background: #8a7a4a; }
  .legend-dot--new        { background: #5a7a9a; }
  .legend-dot--lookout    { background: var(--color-accent); }
  .legend-diamond {
    width: 7px; height: 7px; border: 1.5px solid; transform: rotate(45deg); flex-shrink: 0;
  }
  .legend-diamond--phenomenon { border-color: #c0622a; }
  .legend-diamond--standard   { border-color: #5a7a5a; }
  .legend-diamond--approximate{ border-color: #8a7a4a; border-style: dashed; }
</style>

<script>
  // ─── Layer toggles ────────────────────────────────────────────────────────
  document.querySelectorAll<HTMLButtonElement>('.toggle').forEach(btn => {
    btn.addEventListener('click', () => {
      const isOn = btn.classList.toggle('on');
      btn.classList.toggle('off', !isOn);
      const layer = btn.dataset.layer;
      if (!layer) return;
      const el = document.getElementById(layer + '-layer');
      if (el) el.style.display = isOn ? '' : 'none';
      const broadcastEl = document.getElementById('broadcast-layer');
      if (layer === 'broadcast' && broadcastEl) broadcastEl.style.display = isOn ? '' : 'none';
    });
  });

  // ─── Session filter pills ─────────────────────────────────────────────────
  document.querySelectorAll<HTMLButtonElement>('.pill').forEach(pill => {
    pill.addEventListener('click', () => {
      pill.classList.toggle('active');
      applySessionFilter();
    });
  });

  function applySessionFilter() {
    const active = new Set(
      [...document.querySelectorAll<HTMLButtonElement>('.pill.active')]
        .map(p => p.dataset.session)
    );
    // Filter phenomenon markers
    document.querySelectorAll<SVGGElement>('.phenom-marker').forEach(m => {
      const sessions = (m.dataset.session ?? '').split(',');
      const show = sessions.some(s => active.has(s));
      m.style.display = show ? '' : 'none';
    });
    // Filter caller markers
    document.querySelectorAll<SVGGElement>('.caller-marker').forEach(m => {
      const show = active.has(m.dataset.session);
      m.style.display = show ? '' : 'none';
    });
  }

  // ─── Marker selection & detail panel ─────────────────────────────────────
  function showPane(paneId: string) {
    document.getElementById('detail-empty')!.hidden = true;
    document.querySelectorAll<HTMLElement>('.detail-pane').forEach(p => { p.hidden = true; });
    const pane = document.getElementById(paneId);
    if (pane) {
      pane.hidden = false;
      // Reset scroll position and update chevron state
      const trackId = pane.querySelector<HTMLElement>('.detail-track')?.id;
      if (trackId) updateChevrons(trackId);
    }
  }

  // Phenomenon markers
  document.querySelectorAll<SVGGElement>('.phenom-marker').forEach(marker => {
    marker.addEventListener('click', () => {
      document.querySelectorAll('.phenom-marker, .caller-marker').forEach(m => m.classList.remove('selected'));
      marker.classList.add('selected');
      const key = marker.dataset.key;
      if (key) showPane(`pane-${key}`);
    });
    marker.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' ') marker.click();
    });
  });

  // Caller markers
  document.querySelectorAll<SVGGElement>('.caller-marker').forEach(marker => {
    marker.addEventListener('click', () => {
      document.querySelectorAll('.phenom-marker, .caller-marker').forEach(m => m.classList.remove('selected'));
      marker.classList.add('selected');
      const idx = marker.dataset.index;
      if (idx !== undefined) showPane(`pane-caller-${idx}`);
    });
    marker.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' ') marker.click();
    });
  });

  // ─── Vertical chevron scroll ──────────────────────────────────────────────
  function updateChevrons(trackId: string) {
    const track = document.getElementById(trackId);
    if (!track) return;
    const pane = track.closest('.detail-pane');
    if (!pane) return;
    const upBtn  = pane.querySelector<HTMLElement>('.scroll-btn--up');
    const downBtn = pane.querySelector<HTMLElement>('.scroll-btn--down');
    const canScroll = track.scrollHeight > track.clientHeight + 2;
    const atTop    = track.scrollTop <= 1;
    const atBottom = track.scrollTop >= track.scrollHeight - track.clientHeight - 1;
    upBtn?.classList.toggle('scroll-btn--hidden', !canScroll || atTop);
    downBtn?.classList.toggle('scroll-btn--hidden', !canScroll || atBottom);
  }

  document.querySelectorAll<HTMLButtonElement>('.scroll-btn--vert').forEach(btn => {
    btn.addEventListener('click', () => {
      const trackId = btn.dataset.track;
      if (!trackId) return;
      const track = document.getElementById(trackId);
      if (!track) return;
      const dir = btn.classList.contains('scroll-btn--up') ? -1 : 1;
      track.scrollBy({ top: dir * 120, behavior: 'smooth' });
    });
  });

  document.querySelectorAll<HTMLElement>('.detail-track').forEach(track => {
    track.addEventListener('scroll', () => updateChevrons(track.id), { passive: true });
  });

  // ─── Coordinate readout on map hover ─────────────────────────────────────
  const svg = document.getElementById('transmission-svg') as SVGSVGElement | null;
  const coordsEl = document.getElementById('map-coords');
  if (svg && coordsEl) {
    svg.addEventListener('mousemove', (e) => {
      const rect = svg.getBoundingClientRect();
      const xRatio = (e.clientX - rect.left) / rect.width;
      const yRatio = (e.clientY - rect.top) / rect.height;
      const lon = (-116.2 + xRatio * 12.0).toFixed(2);
      const lat = (49.2 - yRatio * 1.8).toFixed(2);
      coordsEl.textContent = `${lat}° N · ${Math.abs(parseFloat(lon))}° W`;
    });
  }
</script>
