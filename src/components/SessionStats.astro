---
interface Stats {
  blocks_completed: number;
  total_callers: number;
  phenomenon_callers: number;
  standard_callers: number;
  calls_resolved: number;
  calls_unresolved: number;
  dawn_colour?: string;
  veil_at_close?: string;
}

interface Props {
  stats: Stats;
}

const { stats } = Astro.props;

const rows = [
  { label: 'Blocks completed', value: stats.blocks_completed },
  { label: 'Total callers', value: stats.total_callers },
  { label: 'Phenomenon callers', value: stats.phenomenon_callers },
  { label: 'Standard callers', value: stats.standard_callers },
  { label: 'Calls resolved', value: stats.calls_resolved },
  { label: 'Calls unresolved', value: stats.calls_unresolved },
  ...(stats.dawn_colour ? [{ label: 'Dawn colour', value: stats.dawn_colour }] : []),
  ...(stats.veil_at_close ? [{ label: 'Veil at close', value: stats.veil_at_close }] : []),
];
---

<section class="stats-section">
  <h2 class="stats-section__title">Session Statistics</h2>
  <dl class="stats-grid">
    {rows.map(row => (
      <>
        <dt class="stats-grid__label mono">{row.label}</dt>
        <dd class="stats-grid__value">{row.value}</dd>
      </>
    ))}
  </dl>
</section>

<style>
  .stats-section {
    margin-top: var(--space-2xl);
  }

  .stats-section__title {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin-bottom: var(--space-lg);
    padding-bottom: var(--space-sm);
    border-bottom: 1px solid var(--color-border);
  }

  .stats-grid {
    display: grid;
    grid-template-columns: max-content 1fr;
    gap: var(--space-xs) var(--space-xl);
    font-size: 0.9rem;
  }

  .stats-grid__label {
    font-size: 0.72rem;
    letter-spacing: 0.06em;
    color: var(--color-text-muted);
    text-align: right;
    padding-right: var(--space-md);
    border-right: 1px solid var(--color-border);
    align-self: center;
  }

  .stats-grid__value {
    color: var(--color-text);
    align-self: center;
  }
</style>
